{
    "发布": {
        "1": "pytest -q",
        "2": {
            "cmd": "pnpm run build:flatten",
            "cwd": "./web-ui"
        },
        "3": "cz changelog --incremental",
        "4": "cz bump $1",
        "5": "python3 -m build",
        "6": "git push origin --tags",
        "7": "twine upload dist/*"
    },

    "清理文件": "find . -type d \\( -name '__pycache__' -o -name '.pytest_cache' \\) -exec rm -rf {} +",
    "本地标签": "git tag",
    "查看远程库标签": "git ls-remote --tags origin"
}