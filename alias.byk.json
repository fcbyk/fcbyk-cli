{
    "发布": {
        "1": "pytest -q",
        "2": "cz changelog --incremental",
        "3": "cz bump $1",
        "4": "python3 -m build",
        "5": "git push origin --tags",
        "6": "twine upload dist/*"
    },

    "清理文件": "find . -type d \\( -name '__pycache__' -o -name '.pytest_cache' \\) -exec rm -rf {} +",
    "本地标签": "git tag",
    "查看远程库标签": "git ls-remote --tags origin",
    "回滚": "git reset --soft HEAD~1"
}